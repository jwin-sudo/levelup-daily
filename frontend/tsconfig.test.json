{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["es2023"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "outDir": "./.test-dist",
    "rootDir": "."
  },
  "include": ["src/api/**/*.ts", "src/stores/**/*.ts", "src/types.ts", "tests/**/*.ts"],
  "exclude": ["src/main.tsx", "src/runtime-env*.ts"]
}